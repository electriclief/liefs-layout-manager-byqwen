{
  "name": "@liefs/layout-manager",
  "version": "4.0.0-dev.0",
  "description": "Modern dynamic layout manager with Flexbox, TypeScript, and full test coverage",
  "type": "module",
  "main": "./dist/liefs-layout-manager.umd.cjs",
  "module": "./dist/liefs-layout-manager.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/liefs-layout-manager.js",
      "require": "./dist/liefs-layout-manager.umd.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "docs": "typedoc src/index.ts --out docs/api"
  },
  "keywords": [
    "layout",
    "layout-manager",
    "flexbox",
    "resizable",
    "panels",
    "typescript",
    "ui",
    "components"
  ],
  "author": "Stacy Lief Kelly",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/electriclief/liefs-layout-manager-byqwen.git"
  },
  "bugs": {
    "url": "https://github.com/electriclief/liefs-layout-manager-byqwen/issues"
  },
  "homepage": "https://github.com/electriclief/liefs-layout-manager-byqwen#readme",
  "devDependencies": {
    "@playwright/test": "^1.42.0",
    "@types/node": "^20.11.24",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "@vitest/coverage-v8": "^1.3.1",
    "eslint": "^8.57.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.2.5",
    "typedoc": "^0.25.12",
    "typescript": "^5.3.3",
    "vite": "^5.1.4",
    "vite-plugin-dts": "^3.7.3",
    "vitest": "^1.3.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
